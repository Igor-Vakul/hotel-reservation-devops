# MySQL
MYSQL_ROOT_PASSWORD=rootpass_change_me
MYSQL_DATABASE=hotel
MYSQL_USER=hotel
MYSQL_PASSWORD=hotelpass_change_me

# Backend -> MySQL (service name 'mysql' resolves on the compose network)
CONNECTIONSTRINGS__DEFAULT=Server=mysql;Port=3306;Database=hotel;User=hotel;Password=hotelpass_change_me;

# JWT (generate a long random secret; never commit real .env)
Jwt__Secret=change-me-to-a-long-random-string-min-32-chars
Jwt__Issuer=hotel-api
Jwt__ExpiryMinutes=120

# Bootstrap admin (created at startup if missing; never commit a real password)
Admin__Email=admin@hotel.local
Admin__Password=change-me-strong-admin-password
